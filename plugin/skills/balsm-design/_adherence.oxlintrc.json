{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Badge/**",
              "components/Button/**",
              "components/DatePicker/**",
              "components/Input/**",
              "components/LoadingOverlay/**",
              "components/ProSidebar/**",
              "components/Progress/**",
              "components/ProgressButton/**",
              "components/SegmentedProgress/**",
              "components/Select/**",
              "components/Skeleton/**",
              "components/Spinner/**",
              "components/Steps/**",
              "components/TimePicker/**",
              "components/Toast/**",
              "components/TopLoadingBar/**",
              "patient_app/**",
              "ui_kits/balsm_pharmacy/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|IBM Plex Sans|IBM Plex Sans Arabic|IBM Plex Mono|Cairo))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, IBM Plex Sans, IBM Plex Sans Arabic, IBM Plex Mono, Cairo."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|dot|icon|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, dot, icon, onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|icon|iconTrailing|fullWidth|children|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, icon, iconTrailing, fullWidth, children, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DatePicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|label|hint|error|placeholder|disabled|clearable|min|max|size|fullWidth|weekStartsMonday|id|dir|className|style|key|ref|className|style|children)$/]",
        "message": "<DatePicker> doesn't accept that prop. Declared props: value, onChange, label, hint, error, placeholder, disabled, clearable, min, max, size, fullWidth, weekStartsMonday, id, dir, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DatePicker'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:ltr|rtl)$/]",
        "message": "<DatePicker> dir must be one of 'ltr' | 'rtl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|hint|error|leadingIcon|trailingIcon|size|fullWidth|multiline|rows|dir|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, label, hint, error, leadingIcon, trailingIcon, size, fullWidth, multiline, rows, dir, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|search|tel|url)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'search' | 'tel' | 'url'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:ltr|rtl|auto)$/]",
        "message": "<Input> dir must be one of 'ltr' | 'rtl' | 'auto'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadingOverlay'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|variant|message|submessage|progress|indeterminate|spinner|contained|backgroundImage|key|ref|className|style|children)$/]",
        "message": "<LoadingOverlay> doesn't accept that prop. Declared props: open, variant, message, submessage, progress, indeterminate, spinner, contained, backgroundImage."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadingOverlay'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:cream|scrim|brand)$/]",
        "message": "<LoadingOverlay> variant must be one of 'cream' | 'scrim' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadingOverlay'] > JSXAttribute[name.name='spinner'] > Literal[value!=/^(?:petal|ring)$/]",
        "message": "<LoadingOverlay> spinner must be one of 'petal' | 'ring'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|variant|size|label|showValue|indeterminate|striped|state|format|key|ref|className|style|children)$/]",
        "message": "<Progress> doesn't accept that prop. Declared props: value, variant, size, label, showValue, indeterminate, striped, state, format."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:progress|loading|indeterminate|variant|size|showPct|children|key|ref|className|style|children)$/]",
        "message": "<ProgressButton> doesn't accept that prop. Declared props: progress, loading, indeterminate, variant, size, showPct, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<ProgressButton> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<ProgressButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProSidebarNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|count|onClick|key|ref|className|style|children)$/]",
        "message": "<ProSidebarNavItem> doesn't accept that prop. Declared props: id, label, icon, count, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MeterSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|color|hex|key|ref|className|style|children)$/]",
        "message": "<MeterSegment> doesn't accept that prop. Declared props: label, value, color, hex."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|width|height|lines|lastWidth|radius|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: variant, width, height, lines, lastWidth, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|thickness|variant|label|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, thickness, variant, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|status|key|ref|className|style|children)$/]",
        "message": "<StepItem> doesn't accept that prop. Declared props: label, description, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimePicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|label|hint|error|placeholder|disabled|clearable|minuteStep|use12Hour|min|max|size|fullWidth|id|dir|className|style|key|ref|className|style|children)$/]",
        "message": "<TimePicker> doesn't accept that prop. Declared props: value, onChange, label, hint, error, placeholder, disabled, clearable, minuteStep, use12Hour, min, max, size, fullWidth, id, dir, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimePicker'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:ltr|rtl)$/]",
        "message": "<TimePicker> dir must be one of 'ltr' | 'rtl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToastOptions'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|message|action|duration|closeable|key|ref|className|style|children)$/]",
        "message": "<ToastOptions> doesn't accept that prop. Declared props: variant, title, message, action, duration, closeable."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopLoadingBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|loading|variant|height|contained|indeterminate|key|ref|className|style|children)$/]",
        "message": "<TopLoadingBar> doesn't accept that prop. Declared props: value, loading, variant, height, contained, indeterminate."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopLoadingBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|success|brand)$/]",
        "message": "<TopLoadingBar> variant must be one of 'primary' | 'accent' | 'success' | 'brand'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
